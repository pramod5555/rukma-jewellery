<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Nunito:wght@300;400;500;600&family=Inter:wght@300;400;500&family=Cormorant+Garamond:wght@300;400;500&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Newsreader:ital,wght@0,300;0,400;1,300;1,400&family=Outfit:wght@300;400;500&family=Manrope:wght@300;400;500&display=swap" rel="stylesheet">
    {% # Inlined CSS Variables %}
    {% render 'css-variables' %}

    {% comment %}
      Font preloading:
      1. Preconnect to font CDN for faster connection
      2. Preload only the critical font variant (base weight)
      3. Additional variants load on-demand via @font-face
    {% endcomment %}
    {% unless settings.type_primary_font.system? %}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>

      {% comment %} Preload the base font variant for initial page render {% endcomment %}
      {{ settings.type_primary_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
    {% endunless %}

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    {{ content_for_header }}
  </head>

  <body class="template--{{ template.name }}{% if page %} page-{{ page.handle }}{% endif %}{% if template.suffix != blank %} template-page-{{ template.suffix }}{% endif %}">
    {% sections 'header-group' %}

    <style>
      main, .main-content, .page-width, #MainContent {
        overflow-x: hidden;
      }

      /* Transparent navbar -- only on landing/home page */
      .page-home .rukma-header,
      .page-home header,
      .template-page-rukma-landing .rukma-header,
      .template-page-rukma-landing header,
      .site-header,
      header.header,
      [class*="site-header"] {
        position: fixed !important;
        top: 0 !important;
        left: 0 !important;
        right: 0 !important;
        z-index: 100 !important;
        background: transparent !important;
        border-bottom: none !important;
        transition: background 0.4s ease, border-color 0.4s ease !important;
      }

      .page-home .rukma-header.scrolled,
      .template-page-rukma-landing .rukma-header.scrolled {
        background: #F5EDE0 !important;
        border-bottom: 1px solid rgba(44, 36, 32, 0.08) !important;
      }

      .page-home .rukma-header:not(.scrolled) a,
      .page-home .rukma-header:not(.scrolled) .rukma-header__nav-link,
      .template-page-rukma-landing .rukma-header:not(.scrolled) a,
      .template-page-rukma-landing .rukma-header:not(.scrolled) .rukma-header__nav-link,
      .template-page-rukma-landing .rukma-header:not(.scrolled) nav a {
        color: #F5EDE0 !important;
        opacity: 0.92 !important;
        text-shadow: 0 1px 4px rgba(0, 0, 0, 0.3) !important;
      }

      .page-home .rukma-header:not(.scrolled) .rukma-header__logo-text,
      .template-page-rukma-landing .rukma-header:not(.scrolled) .rukma-header__logo-text,
      .template-page-rukma-landing .rukma-header:not(.scrolled) [class*="logo-text"] {
        color: #F5EDE0 !important;
        opacity: 0.92 !important;
        text-shadow: 0 1px 4px rgba(0, 0, 0, 0.3) !important;
      }

      .page-home .rukma-header:not(.scrolled) .rukma-header__logo-mark img,
      .template-page-rukma-landing .rukma-header:not(.scrolled) .rukma-header__logo-mark img {
        filter: brightness(0) invert(1) !important;
      }

      .page-home .rukma-header:not(.scrolled) .rukma-header__cart,
      .page-home .rukma-header:not(.scrolled) .rukma-header__cart svg,
      .template-page-rukma-landing .rukma-header:not(.scrolled) .rukma-header__cart,
      .template-page-rukma-landing .rukma-header:not(.scrolled) .rukma-header__cart svg {
        color: #F5EDE0 !important;
        stroke: #F5EDE0 !important;
        opacity: 0.92 !important;
      }

      .page-home .rukma-header.scrolled a,
      .page-home .rukma-header.scrolled nav a,
      .page-home .rukma-header.scrolled .rukma-header__nav-link,
      .template-page-rukma-landing .rukma-header.scrolled a,
      .template-page-rukma-landing .rukma-header.scrolled nav a,
      .template-page-rukma-landing .rukma-header.scrolled .rukma-header__nav-link {
        color: #2C2420 !important;
        text-shadow: none !important;
        opacity: 1 !important;
      }

      .page-home .rukma-header.scrolled .rukma-header__cart,
      .page-home .rukma-header.scrolled .rukma-header__cart svg,
      .template-page-rukma-landing .rukma-header.scrolled .rukma-header__cart,
      .template-page-rukma-landing .rukma-header.scrolled .rukma-header__cart svg {
        color: #2C2420 !important;
        stroke: #2C2420 !important;
      }
    </style>

    {{ content_for_layout }}

    {% sections 'footer-group' %}

    <script>
      (function() {
        var header = document.querySelector('.rukma-header, .site-header, header.header');
        if (!header) return;

        var isLanding = document.body.classList.contains('page-home') ||
          document.body.classList.contains('template-page-rukma-landing');
        if (!isLanding) return;

        function onScroll() {
          if (window.scrollY > 40) {
            header.classList.add('scrolled');
          } else {
            header.classList.remove('scrolled');
          }
        }

        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      })();
    </script>
  </body>
</html>
