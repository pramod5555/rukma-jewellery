<section
  class="rukma-checkout"
  style="
    --rukma-checkout-bg: {{ section.settings.background_color }};
    --rukma-checkout-surface: {{ section.settings.surface_color }};
    --rukma-checkout-accent: {{ section.settings.accent_color }};
  "
>
  <div class="rukma-checkout-grid">
    <div class="rukma-checkout-flow">
      <nav class="rukma-checkout-steps" aria-label="{{ section.settings.steps_label | escape }}">
        <span class="rukma-checkout-step rukma-checkout-step-active">{{ section.settings.step_one | escape }}</span>
        <span class="rukma-checkout-step">{{ section.settings.step_two | escape }}</span>
        <span class="rukma-checkout-step">{{ section.settings.step_three | escape }}</span>
      </nav>

      <div class="rukma-checkout-form-panel">
        <div>
          <h2 class="rukma-checkout-heading">{{ section.settings.heading | escape }}</h2>
          <p class="rukma-checkout-subheading">{{ section.settings.subheading | escape }}</p>
        </div>

        <div class="rukma-checkout-fields">
          {%- for block in section.blocks -%}
            {%- if block.type == 'field' -%}
              <label class="rukma-checkout-field{% if block.settings.full_width %} rukma-checkout-field-full{% endif %}" {{ block.shopify_attributes }}>
                <span>{{ block.settings.label | escape }}</span>
                <input type="{{ block.settings.input_type }}" placeholder="{{ block.settings.placeholder | escape }}">
              </label>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      <div class="rukma-checkout-delivery">
        <h3 class="rukma-checkout-small-heading">{{ section.settings.delivery_heading | escape }}</h3>
        <div class="rukma-checkout-delivery-grid">
          <div class="rukma-checkout-delivery-option rukma-checkout-delivery-option-active">
            <div>
              <strong>{{ section.settings.delivery_one_title | escape }}</strong>
              <span>{{ section.settings.delivery_one_body | escape }}</span>
            </div>
            <em>{{ section.settings.delivery_one_price | escape }}</em>
          </div>
          <div class="rukma-checkout-delivery-option">
            <div>
              <strong>{{ section.settings.delivery_two_title | escape }}</strong>
              <span>{{ section.settings.delivery_two_body | escape }}</span>
            </div>
            <em>{{ section.settings.delivery_two_price | escape }}</em>
          </div>
        </div>
      </div>

      {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_link | default: routes.cart_url }}" class="rukma-checkout-cta">
          {{ section.settings.cta_label | escape }}
        </a>
      {%- endif -%}
    </div>

    <aside class="rukma-checkout-summary">
      <h2 class="rukma-checkout-summary-title">{{ section.settings.summary_heading | escape }}</h2>

      <div class="rukma-checkout-items">
        {%- for block in section.blocks -%}
          {%- if block.type == 'summary_item' -%}
            <div class="rukma-checkout-item" {{ block.shopify_attributes }}>
              <div class="rukma-checkout-item-media">
                {%- if block.settings.image -%}
                  <img
                    src="{{ block.settings.image | img_url: '1400x' }}"
                    alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                    class="rukma-checkout-item-image"
                    width="1400"
                    height="1400"
                    loading="lazy"
                  >
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'rukma-checkout-item-image rukma-checkout-placeholder' }}
                {%- endif -%}
              </div>
              <div class="rukma-checkout-item-copy">
                <h3>{{ block.settings.title | escape }}</h3>
                <p>{{ block.settings.subtitle | escape }}</p>
                <span>{{ block.settings.price | escape }}</span>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="rukma-checkout-totals">
        <div><span>{{ section.settings.subtotal_label | escape }}</span><strong>{{ section.settings.subtotal | escape }}</strong></div>
        <div><span>{{ section.settings.shipping_label | escape }}</span><strong>{{ section.settings.shipping | escape }}</strong></div>
        <div><span>{{ section.settings.tax_label | escape }}</span><strong>{{ section.settings.taxes | escape }}</strong></div>
        <div class="rukma-checkout-total"><span>{{ section.settings.total_label | escape }}</span><strong>{{ section.settings.total | escape }}</strong></div>
      </div>

      {%- if section.settings.assurance != blank -%}
        <p class="rukma-checkout-assurance">{{ section.settings.assurance | escape }}</p>
      {%- endif -%}
    </aside>
  </div>
</section>

{% stylesheet %}
  .rukma-checkout,
  .rukma-checkout * {
    border-radius: 0;
  }

  .rukma-checkout {
    background: var(--rukma-checkout-bg, var(--color-bg));
    color: var(--color-text);
    font-family: var(--font-body);
    padding: 6rem var(--page-margin);
  }

  .rukma-checkout-grid {
    max-width: var(--page-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(20rem, 5fr);
    gap: 5rem;
    align-items: start;
  }

  .rukma-checkout-flow {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .rukma-checkout-steps,
  .rukma-checkout-small-heading,
  .rukma-checkout-field span,
  .rukma-checkout-cta,
  .rukma-checkout-totals,
  .rukma-checkout-assurance {
    font-family: var(--font-body);
    letter-spacing: var(--letter-spacing-label);
    text-transform: uppercase;
  }

  .rukma-checkout-steps {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-text-secondary) 20%, transparent);
    color: var(--color-text-secondary);
    font-size: 0.62rem;
  }

  .rukma-checkout-step {
    padding-bottom: 1rem;
  }

  .rukma-checkout-step-active {
    color: var(--rukma-checkout-accent, var(--color-velvet));
    border-bottom: 1px solid currentColor;
    margin-bottom: -1px;
  }

  .rukma-checkout-form-panel {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .rukma-checkout-heading,
  .rukma-checkout-summary-title {
    margin: 0;
    font-family: var(--font-heading);
    font-weight: 300;
    font-style: italic;
    color: var(--rukma-checkout-accent, var(--color-velvet));
  }

  .rukma-checkout-heading {
    font-size: clamp(2.4rem, 4vw, 4rem);
  }

  .rukma-checkout-subheading {
    margin: 0.75rem 0 0;
    color: var(--color-text-secondary);
  }

  .rukma-checkout-fields {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 2rem;
  }

  .rukma-checkout-field {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .rukma-checkout-field-full {
    grid-column: 1 / -1;
  }

  .rukma-checkout-field span {
    font-size: 0.62rem;
    color: var(--color-text-secondary);
  }

  .rukma-checkout-field input {
    border: 0;
    border-bottom: 1px solid color-mix(in srgb, var(--color-text-secondary) 35%, transparent);
    background: transparent;
    padding: 0.6rem 0;
    color: var(--color-text);
    font: inherit;
  }

  .rukma-checkout-small-heading {
    margin: 0 0 1.5rem;
    font-size: 0.72rem;
    color: var(--color-text-secondary);
  }

  .rukma-checkout-delivery-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .rukma-checkout-delivery-option {
    border: 1px solid color-mix(in srgb, var(--color-text-secondary) 25%, transparent);
    padding: 1.5rem;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }

  .rukma-checkout-delivery-option-active {
    border-color: var(--rukma-checkout-accent, var(--color-velvet));
    background: var(--rukma-checkout-surface, var(--color-surface));
  }

  .rukma-checkout-delivery-option strong,
  .rukma-checkout-delivery-option span {
    display: block;
  }

  .rukma-checkout-delivery-option strong {
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .rukma-checkout-delivery-option span {
    margin-top: 0.35rem;
    color: var(--color-text-secondary);
    font-size: 0.78rem;
    font-style: italic;
  }

  .rukma-checkout-delivery-option em {
    font-family: var(--font-heading);
    font-style: italic;
  }

  .rukma-checkout-cta {
    align-self: flex-start;
    padding: 1.35rem 4rem;
    background: var(--rukma-checkout-accent, var(--color-velvet));
    color: var(--color-bg);
    font-size: 0.72rem;
  }

  .rukma-checkout-summary {
    position: sticky;
    top: 2rem;
    padding: 3rem;
    background: var(--rukma-checkout-surface, var(--color-surface));
  }

  .rukma-checkout-summary-title {
    font-size: 2.2rem;
    margin-bottom: 2.5rem;
  }

  .rukma-checkout-items {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .rukma-checkout-item {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .rukma-checkout-item-media {
    width: 6rem;
    height: 6rem;
    flex: 0 0 auto;
    background: var(--color-bg);
    overflow: hidden;
  }

  .rukma-checkout-item-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .rukma-checkout-item-copy h3 {
    margin: 0 0 0.3rem;
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 300;
    font-size: 1.1rem;
  }

  .rukma-checkout-item-copy p {
    margin: 0 0 0.45rem;
    color: var(--color-text-secondary);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .rukma-checkout-item-copy span {
    font-size: 0.9rem;
    font-style: italic;
  }

  .rukma-checkout-totals {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid color-mix(in srgb, var(--color-text-secondary) 25%, transparent);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    font-size: 0.62rem;
  }

  .rukma-checkout-totals div {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }

  .rukma-checkout-total {
    margin-top: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid color-mix(in srgb, var(--color-text-secondary) 20%, transparent);
    align-items: flex-end;
  }

  .rukma-checkout-total span,
  .rukma-checkout-total strong {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 300;
    letter-spacing: 0;
    text-transform: none;
  }

  .rukma-checkout-total strong {
    color: var(--rukma-checkout-accent, var(--color-velvet));
  }

  .rukma-checkout-assurance {
    margin: 2rem 0 0;
    padding: 1rem;
    background: var(--color-bg);
    color: var(--color-text-secondary);
    font-size: 0.58rem;
    line-height: 1.6;
  }

  .rukma-checkout-placeholder {
    opacity: 0.28;
  }

  @media (max-width: 980px) {
    .rukma-checkout-grid,
    .rukma-checkout-fields,
    .rukma-checkout-delivery-grid {
      grid-template-columns: 1fr;
    }

    .rukma-checkout-summary {
      position: static;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "RUKMA checkout preview",
  "settings": [
    { "type": "text", "id": "steps_label", "label": "Steps nav label", "default": "Checkout steps" },
    { "type": "text", "id": "step_one", "label": "Step one", "default": "01 Shipping" },
    { "type": "text", "id": "step_two", "label": "Step two", "default": "02 Payment" },
    { "type": "text", "id": "step_three", "label": "Step three", "default": "03 Review" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shipping Information" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Where should we send your artisanal pieces?" },
    { "type": "text", "id": "delivery_heading", "label": "Delivery heading", "default": "Delivery Method" },
    { "type": "text", "id": "delivery_one_title", "label": "Delivery option 1 title", "default": "Standard Courier" },
    { "type": "text", "id": "delivery_one_body", "label": "Delivery option 1 body", "default": "3-5 Business Days" },
    { "type": "text", "id": "delivery_one_price", "label": "Delivery option 1 price", "default": "Complimentary" },
    { "type": "text", "id": "delivery_two_title", "label": "Delivery option 2 title", "default": "Express Secure" },
    { "type": "text", "id": "delivery_two_body", "label": "Delivery option 2 body", "default": "Next Day Delivery" },
    { "type": "text", "id": "delivery_two_price", "label": "Delivery option 2 price", "default": "₹1,200" },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Continue to Payment" },
    { "type": "url", "id": "cta_link", "label": "Button link" },
    { "type": "text", "id": "summary_heading", "label": "Summary heading", "default": "Order Summary" },
    { "type": "text", "id": "subtotal_label", "label": "Subtotal label", "default": "Subtotal" },
    { "type": "text", "id": "subtotal", "label": "Subtotal", "default": "₹166,500" },
    { "type": "text", "id": "shipping_label", "label": "Shipping label", "default": "Shipping" },
    { "type": "text", "id": "shipping", "label": "Shipping", "default": "Complimentary" },
    { "type": "text", "id": "tax_label", "label": "Tax label", "default": "Taxes (GST)" },
    { "type": "text", "id": "taxes", "label": "Taxes", "default": "₹4,995" },
    { "type": "text", "id": "total_label", "label": "Total label", "default": "Total" },
    { "type": "text", "id": "total", "label": "Total", "default": "₹171,495" },
    { "type": "text", "id": "assurance", "label": "Assurance text", "default": "Insured express shipping & 14-day archival return policy applies." },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#F5EDE0" },
    { "type": "color", "id": "surface_color", "label": "Surface color", "default": "#EDE6D8" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#731C28" }
  ],
  "blocks": [
    {
      "type": "field",
      "name": "Field",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "First Name" },
        { "type": "text", "id": "placeholder", "label": "Placeholder", "default": "Ananya" },
        { "type": "select", "id": "input_type", "label": "Input type", "default": "text", "options": [
          { "value": "text", "label": "Text" },
          { "value": "tel", "label": "Phone" },
          { "value": "email", "label": "Email" }
        ] },
        { "type": "checkbox", "id": "full_width", "label": "Full width", "default": false }
      ]
    },
    {
      "type": "summary_item",
      "name": "Summary item",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "The Eternal Marigold Necklace" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "22K Gold • Ruby Accent" },
        { "type": "text", "id": "price", "label": "Price", "default": "₹124,000" }
      ]
    }
  ],
  "presets": [
    {
      "name": "RUKMA checkout preview",
      "blocks": [
        { "type": "field", "settings": { "label": "First Name", "placeholder": "Ananya" } },
        { "type": "field", "settings": { "label": "Last Name", "placeholder": "Iyer" } },
        { "type": "field", "settings": { "label": "Address", "placeholder": "7th Floor, Lotus Building, Marine Drive", "full_width": true } },
        { "type": "field", "settings": { "label": "City", "placeholder": "Mumbai" } },
        { "type": "field", "settings": { "label": "Postal Code", "placeholder": "400020" } },
        { "type": "field", "settings": { "label": "Phone Number", "placeholder": "+91 98765 43210", "input_type": "tel", "full_width": true } },
        { "type": "summary_item", "settings": { "title": "The Eternal Marigold Necklace", "subtitle": "22K Gold • Ruby Accent", "price": "₹124,000" } },
        { "type": "summary_item", "settings": { "title": "Temple Arch Hoops", "subtitle": "18K Solid Gold", "price": "₹42,500" } }
      ]
    }
  ]
}
{% endschema %}
