<section class="rukma-hero full-width">
  <div class="rukma-hero__grid">
    <div class="rukma-hero__pillar rukma-hero__pillar--left">
      {%- if section.settings.pillar_left_image -%}
        {{ section.settings.pillar_left_image
          | image_url: width: 800
          | image_tag: loading: 'eager', class: 'rukma-hero__pillar-img'
        }}
      {%- else -%}
        <div class="rukma-hero__pillar-placeholder">Pillar</div>
      {%- endif -%}
    </div>

    <div class="rukma-hero__center">
      {%- if section.settings.video_url != blank -%}
        <video
          class="rukma-hero__bg"
          src="{{ section.settings.video_url }}"
          autoplay
          muted
          loop
          playsinline
        ></video>
      {%- elsif section.settings.hero_image -%}
        {{ section.settings.hero_image
          | image_url: width: 1600
          | image_tag: loading: 'eager', class: 'rukma-hero__bg'
        }}
      {%- else -%}
        <div class="rukma-hero__film-placeholder">
          <span>{{ section.settings.film_placeholder }}</span>
        </div>
      {%- endif -%}

      {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.cta_label != blank -%}
        <div class="rukma-hero__copy">
        {%- if section.settings.eyebrow != blank -%}
          <p class="rukma-hero__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h1 class="rukma-hero__heading">{{ section.settings.heading }}</h1>
        {%- endif -%}
        {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
          <a href="{{ section.settings.cta_url }}" class="rukma-hero__cta">
            {{- section.settings.cta_label -}}
          </a>
        {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    <div class="rukma-hero__pillar rukma-hero__pillar--right">
      {%- if section.settings.pillar_right_image -%}
        {{ section.settings.pillar_right_image
          | image_url: width: 800
          | image_tag: loading: 'eager', class: 'rukma-hero__pillar-img'
        }}
      {%- else -%}
        <div class="rukma-hero__pillar-placeholder">Pillar</div>
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.statement != blank -%}
    <div class="rukma-hero__statement">
      <p>{{ section.settings.statement }}</p>
    </div>
  {%- endif -%}
</section>

{% stylesheet %}
  .rukma-hero {
    background-color: var(--color-bg);
  }

  .rukma-hero__grid {
    display: grid;
    grid-template-columns: 120px minmax(0, 1fr) 120px;
    min-height: calc(100svh - 4.8rem);
    align-items: stretch;
  }

  .rukma-hero__pillar {
    position: relative;
    background-color: var(--color-surface);
  }

  .rukma-hero__pillar-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .rukma-hero__pillar--right .rukma-hero__pillar-img {
    transform: scaleX(-1);
  }

  .rukma-hero__pillar-placeholder {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    font-family: var(--font-body);
    font-size: 0.6rem;
    letter-spacing: var(--letter-spacing-label);
    text-transform: uppercase;
    color: rgba(44, 36, 32, 0.35);
    writing-mode: vertical-rl;
    text-orientation: mixed;
  }

  .rukma-hero__center {
    position: relative;
    min-width: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #1a0a08;
  }

  .rukma-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .rukma-hero__film-placeholder {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    background-color: #1a0a08;
  }

  .rukma-hero__film-placeholder span {
    font-family: var(--font-heading);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(2.5rem, 7vw, 6rem);
    letter-spacing: 0.12em;
    color: rgba(245, 237, 224, 0.78);
    text-transform: uppercase;
  }

  .rukma-hero__copy {
    position: absolute;
    left: 3rem;
    right: 3rem;
    bottom: 3rem;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
  }

  .rukma-hero__eyebrow {
    font-family: var(--font-body);
    font-size: 0.6rem;
    letter-spacing: var(--letter-spacing-label);
    text-transform: uppercase;
    color: #F5EDE0;
    opacity: 0.75;
  }

  .rukma-hero__heading {
    font-family: var(--font-heading);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(2.4rem, 4vw, 4rem);
    line-height: 1.0;
    letter-spacing: 0.05em;
    color: #F5EDE0;
  }

  .rukma-hero__cta {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.6rem;
    letter-spacing: var(--letter-spacing-label);
    text-transform: uppercase;
    color: #F5EDE0;
    border-bottom: 1px solid rgba(245, 237, 224, 0.6);
    padding-bottom: 0.3rem;
    align-self: flex-start;
    transition: opacity 0.2s;
  }

  .rukma-hero__cta:hover {
    opacity: 0.65;
  }

  .rukma-hero__statement {
    display: grid;
    place-items: center;
    min-height: 42vh;
    padding: 120px var(--page-margin);
    text-align: center;
  }

  .rukma-hero__statement p {
    max-width: 16ch;
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(3rem, 6vw, 5rem);
    line-height: 0.95;
    letter-spacing: 0.05em;
    color: var(--color-text);
  }

  @media (max-width: 768px) {
    .rukma-hero__grid {
      grid-template-columns: 1fr;
      min-height: 60vh;
    }

    .rukma-hero__pillar {
      display: none;
    }

    .rukma-hero__center {
      min-height: 60vh;
    }

    .rukma-hero__copy {
      left: 1.5rem;
      right: 1.5rem;
      bottom: 2rem;
    }

    .rukma-hero__statement {
      min-height: auto;
      padding: 96px var(--page-margin);
    }
  }
{% endstylesheet %}

{% schema %}
