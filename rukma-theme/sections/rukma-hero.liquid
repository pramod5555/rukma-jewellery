      "default": "Heritage jewellery"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.rukma_hero.heading"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "t:sections.rukma_hero.cta_label",
