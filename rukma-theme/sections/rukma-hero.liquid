    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "t:sections.rukma_hero.cta_url"
    },
    {
      "type": "text",
      "id": "statement",
      "label": "t:sections.rukma_hero.statement",
      "default": "Heritage jewellery for the contemporary Indian"
    }
  ],
  "presets": [
    {
      "name": "t:sections.rukma_hero.name"
    }
  ]
}
{% endschema %}
