<section class="rukma-search">
  <div class="rukma-search__inner">

    <header class="rukma-search__header">
      <h1 class="rukma-search__title">{{ 'search.title' | t }}</h1>
    </header>

    <div class="rukma-search__form-wrap">
      <form action="{{ routes.search_url }}" method="get" role="search" class="rukma-search__form">
        <input type="hidden" name="type" value="product,article,page">
        <div class="rukma-search__input-wrap">
          <input
            type="search"
            name="q"
            class="rukma-search__input"
            value="{{ search.terms | escape }}"
            placeholder="{{ 'search.placeholder' | t }}"
            aria-label="{{ 'search.title' | t }}"
            autocomplete="off"
          >
          <button type="submit" class="rukma-search__submit" aria-label="{{ 'search.submit' | t }}">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="11" r="7"></circle>
              <line x1="16.5" y1="16.5" x2="22" y2="22"></line>
            </svg>
          </button>
        </div>
      </form>
    </div>

    {%- if search.performed -%}
      {%- assign escaped_terms = search.terms | escape -%}
      {%- if search.results_count == 0 -%}
        <p class="rukma-search__no-results">
          {{ 'search.no_results_html' | t: terms: escaped_terms }}
        </p>
      {%- else -%}
        <p class="rukma-search__results-count">
          {{ 'search.results_for_html' | t: terms: escaped_terms, count: search.results_count }}
        </p>

        {%- paginate search.results by 20 -%}
          <div class="rukma-search__grid">
            {%- for result in search.results -%}
              {%- assign featured_image = result.featured_image | default: result.image -%}
              <a href="{{ result.url }}" class="rukma-search-card">
                <div class="rukma-search-card__img-wrap">
                  {%- if featured_image -%}
                    {{ featured_image
                      | image_url: width: 600
                      | image_tag:
                        loading: 'lazy',
                        class: 'rukma-search-card__img',
                        alt: featured_image.alt | default: result.title
                    }}
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'rukma-search-card__img rukma-search-card__img--placeholder' }}
                  {%- endif -%}
                </div>
                <div class="rukma-search-card__body">
                  <p class="rukma-search-card__type">{{ result.object_type | default: 'product' }}</p>
                  <p class="rukma-search-card__title">{{ result.title | escape }}</p>
                  {%- if result.price -%}
                    <p class="rukma-search-card__price">{{ result.price | money }}</p>
                  {%- endif -%}
                </div>
              </a>
            {%- endfor -%}
          </div>

          {%- if paginate.pages > 1 -%}
            <div class="rukma-search__pagination">
              {{ paginate | default_pagination }}
            </div>
          {%- endif -%}
        {%- endpaginate -%}
      {%- endif -%}
    {%- endif -%}

  </div>
</section>

{% stylesheet %}
  .rukma-search {
    background: var(--color-bg, #F5EDE0);
    padding: 6rem 2rem 8rem;
    min-height: 60vh;
  }

  .rukma-search__inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .rukma-search__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .rukma-search__title {
    font-family: var(--font-heading);
    font-weight: 300;
    font-size: clamp(2rem, 5vw, 3.25rem);
    letter-spacing: -0.01em;
    color: var(--color-text, #2C2420);
  }

  .rukma-search__form-wrap {
    max-width: 580px;
    margin: 0 auto 4rem;
  }

  .rukma-search__input-wrap {
    display: flex;
    border: 1px solid rgba(44, 36, 32, 0.2);
    background: transparent;
    transition: border-color 0.2s;
  }

  .rukma-search__input-wrap:focus-within {
    border-color: var(--color-text, #2C2420);
  }

  .rukma-search__input {
    flex: 1;
    background: transparent;
    border: none;
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-text, #2C2420);
    padding: 1rem 1.25rem;
    outline: none;
    min-width: 0;
  }

  .rukma-search__input::placeholder {
    color: var(--color-text-secondary, #8A7E76);
  }

  .rukma-search__submit {
    background: transparent;
    border: none;
    padding: 0 1.25rem;
    color: var(--color-text-secondary, #8A7E76);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
  }

  .rukma-search__submit:hover {
    color: var(--color-text, #2C2420);
  }

  .rukma-search__no-results,
  .rukma-search__results-count {
    font-family: var(--font-body);
    font-size: 0.7rem;
    letter-spacing: var(--letter-spacing-label, 0.2em);
    text-transform: uppercase;
    color: var(--color-text-secondary, #8A7E76);
    text-align: center;
    margin-bottom: 3rem;
  }

  .rukma-search__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2.5rem 2rem;
  }

  .rukma-search-card {
    display: block;
    color: var(--color-text, #2C2420);
  }

  .rukma-search-card__img-wrap {
    aspect-ratio: 1 / 1;
    background: var(--color-surface, #EDE6D8);
    overflow: hidden;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.35s;
  }

  .rukma-search-card:hover .rukma-search-card__img-wrap {
    background: #e4dece;
  }

  .rukma-search-card__img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .rukma-search-card__img--placeholder {
    width: 60%;
    height: 60%;
    opacity: 0.25;
  }

  .rukma-search-card__type {
    font-family: var(--font-body);
    font-size: 0.55rem;
    letter-spacing: var(--letter-spacing-label, 0.2em);
    text-transform: uppercase;
    color: var(--color-text-secondary, #8A7E76);
    margin-bottom: 0.35rem;
  }

  .rukma-search-card__title {
    font-family: var(--font-heading);
    font-weight: 300;
    font-size: 0.95rem;
    letter-spacing: 0.03em;
    color: var(--color-text, #2C2420);
    line-height: 1.4;
  }

  .rukma-search-card__price {
    font-family: var(--font-body);
    font-size: 0.7rem;
    letter-spacing: var(--letter-spacing-label, 0.2em);
    text-transform: uppercase;
    color: var(--color-text-secondary, #8A7E76);
    margin-top: 0.4rem;
  }

  .rukma-search__pagination {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 5rem;
    font-family: var(--font-body);
    font-size: 0.65rem;
    letter-spacing: var(--letter-spacing-label, 0.2em);
    text-transform: uppercase;
  }

  .rukma-search__pagination a,
  .rukma-search__pagination span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.5rem;
    height: 2.5rem;
    padding: 0 0.5rem;
    color: var(--color-text-secondary, #8A7E76);
    border: 1px solid transparent;
    transition: border-color 0.2s, color 0.2s;
  }

  .rukma-search__pagination a:hover {
    border-color: rgba(44, 36, 32, 0.2);
    color: var(--color-text, #2C2420);
  }

  .rukma-search__pagination .current {
    border-color: var(--color-text, #2C2420);
    color: var(--color-text, #2C2420);
  }

  @media (max-width: 900px) {
    .rukma-search__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 600px) {
    .rukma-search {
      padding: 4rem 1.25rem 5rem;
    }

    .rukma-search__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem 1rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.search",
  "settings": []
}
{% endschema %}
