{% if template.name == 'product' %}
<style>
  body {
    background-color: #731C28 !important;
    color: #F5EDE0 !important;
  }

  /* Position header over velvet — only the header wrapper, not nav children */
  .rukma-header {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    right: 0 !important;
    width: 100% !important;
    background-color: transparent !important;
  }

  /* Cream text for all header children */
  .rukma-header__logo,
  .rukma-header__nav-link,
  .rukma-header__cart {
    color: #F5EDE0 !important;
  }

  .rukma-header__nav-link:hover,
  .rukma-header__nav-link.is-active {
    color: rgba(245, 237, 224, 0.55) !important;
  }

  .rukma-header svg {
    stroke: #F5EDE0 !important;
    fill: none !important;
  }

  .rukma-header__hamburger span {
    background-color: #F5EDE0 !important;
  }

  /* Remove any background from the image area */
  .rukma-pdp__media,
  .rukma-pdp__image-wrap {
    background: transparent !important;
  }

  /* Sold out: ghost button on dark background */
  .rukma-pdp__add-btn:disabled {
    background-color: transparent !important;
    border: 1px solid rgba(245, 237, 224, 0.4) !important;
    color: rgba(245, 237, 224, 0.6) !important;
    opacity: 1 !important;
  }
</style>
{% endif %}

{%- assign current_variant = product.selected_or_first_available_variant -%}

<div class="rukma-pdp full-width">
  <div class="rukma-pdp__inner">

    <div class="rukma-pdp__media">
      {%- if product.images.size > 0 -%}
        {%- for image in product.images -%}
          <div
            class="rukma-pdp__image-wrap{% if forloop.first %} is-active{% endif %}"
            data-index="{{ forloop.index0 }}"
          >
            {{ image
              | image_url: width: 1200
              | image_tag:
                class: 'rukma-pdp__image',
                loading: 'eager',
                alt: image.alt | default: product.title
            }}
          </div>
        {%- endfor -%}
        {%- if product.images.size > 1 -%}
          <div class="rukma-pdp__thumbs">
            {%- for image in product.images -%}
              <button
                class="rukma-pdp__thumb{% if forloop.first %} is-active{% endif %}"
                data-index="{{ forloop.index0 }}"
                aria-label="{{ image.alt | default: product.title }}"
              >
                {{ image | image_url: width: 120 | image_tag: loading: 'lazy' }}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- else -%}
        <div class="rukma-pdp__image-wrap is-active">
          {{ 'product-1' | placeholder_svg_tag: 'rukma-pdp__image' }}
        </div>
      {%- endif -%}
    </div>

    <div class="rukma-pdp__info">
      {%- if product.vendor != blank -%}
        <p class="rukma-pdp__vendor">{{ product.vendor }}</p>
      {%- endif -%}

      <h1 class="rukma-pdp__title">{{ product.title }}</h1>

      <p class="rukma-pdp__price" id="rukma-price">
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <s class="rukma-pdp__price-was">{{ current_variant.compare_at_price | money }}</s>
        {%- endif -%}
        <span class="rukma-pdp__price-now">{{ current_variant.price | money }}</span>
      </p>

      {%- if product.description != blank -%}
        <div class="rukma-pdp__desc">{{ product.description }}</div>
      {%- endif -%}

      {%- form 'product', product, id: 'rukma-product-form' -%}
        {%- if product.variants.size > 1 -%}
          <div class="rukma-pdp__variants">
            <label class="rukma-pdp__variant-label" for="rukma-variant-select">
              {{- 'products.variant' | t -}}
            </label>
            <select name="id" id="rukma-variant-select" class="rukma-pdp__select">
              {%- for variant in product.variants -%}
                <option
                  value="{{ variant.id }}"
                  {%- if variant == current_variant %} selected{%- endif -%}
                  {%- unless variant.available %} disabled{%- endunless -%}
                >
                  {{ variant.title }} — {{ variant.price | money }}
                </option>
              {%- endfor -%}
            </select>
          </div>
        {%- else -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}">
        {%- endif -%}

        <button
          type="submit"
          class="rukma-pdp__add-btn"
          {%- unless current_variant.available %} disabled{%- endunless -%}
        >
          {%- if current_variant.available -%}
            {{ 'products.add_to_bag' | t }}
          {%- else -%}
            {{ 'products.sold_out' | t }}
          {%- endif -%}
        </button>
      {%- endform -%}
    </div>

  </div>
</div>

<div class="rukma-pdp__sticky-bar" id="rukma-sticky-bar">
  <div class="rukma-pdp__sticky-inner">
    <p class="rukma-pdp__sticky-title">{{ product.title }}</p>
    <div class="rukma-pdp__sticky-right">
      <p class="rukma-pdp__sticky-price">{{ current_variant.price | money }}</p>
      <button type="submit" form="rukma-product-form" class="rukma-pdp__sticky-btn">
        {{ 'products.add_to_bag' | t }}
      </button>
    </div>
  </div>
</div>

{% stylesheet %}
  .rukma-pdp {
    min-height: 100svh;
  }

  .rukma-pdp__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100svh;
    padding-top: 5rem;
  }

  /* ── Media column ── */
  .rukma-pdp__media {
    position: sticky;
    top: 0;
    height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    overflow: hidden;
    background: transparent;
  }

  .rukma-pdp__image-wrap {
    display: none;
    width: 100%;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    padding: 0;
  }

  .rukma-pdp__image-wrap.is-active {
    display: flex;
  }

  .rukma-pdp__image {
    width: 100%;
    max-height: 70vh;
    object-fit: contain;
    display: block;
    background: transparent;
  }

  .rukma-pdp__thumbs {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .rukma-pdp__thumb {
    width: 3rem;
    height: 3rem;
    overflow: hidden;
    background: none;
    border: 1px solid rgba(245, 237, 224, 0.2);
    cursor: pointer;
    padding: 0;
    transition: border-color 0.2s;
  }

  .rukma-pdp__thumb.is-active,
  .rukma-pdp__thumb:hover {
    border-color: rgba(245, 237, 224, 0.75);
  }

  .rukma-pdp__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Info column ── */
  .rukma-pdp__info {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 6rem 4rem 6rem 3rem;
  }

  .rukma-pdp__vendor {
    font-family: var(--font-body);
    font-size: 0.6rem;
    letter-spacing: var(--letter-spacing-label);
    text-transform: uppercase;
    color: rgba(245, 237, 224, 0.5);
    margin-bottom: 1rem;
  }

  .rukma-pdp__title {
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 300;
    font-size: 2.5rem;
    letter-spacing: 0.05em;
    line-height: 1.1;
    color: #F5EDE0;
    margin-bottom: 16px;
  }

  .rukma-pdp__price {
    font-family: var(--font-body);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: rgba(245, 237, 224, 0.7);
    margin-bottom: 48px;
  }

  .rukma-pdp__price-was {
    margin-right: 0.75rem;
    opacity: 0.4;
  }

  .rukma-pdp__desc {
    font-family: var(--font-body);
    font-size: 0.85rem;
    line-height: 1.75;
    color: rgba(245, 237, 224, 0.65);
    max-width: 36ch;
    margin-bottom: 2rem;
  }

  /* Variant select */
  .rukma-pdp__variants {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 2rem;
  }

  .rukma-pdp__variant-label {
    font-family: var(--font-body);
    font-size: 0.6rem;
    letter-spacing: var(--letter-spacing-label);
    text-transform: uppercase;
    color: rgba(245, 237, 224, 0.5);
  }

  .rukma-pdp__select {
    background: transparent;
    color: #F5EDE0;
    border: 1px solid rgba(245, 237, 224, 0.3);
    padding: 0.75rem 1rem;
    font-family: var(--font-body);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    cursor: pointer;
    appearance: none;
    width: 100%;
  }

  .rukma-pdp__select option {
    background-color: #731C28;
    color: #F5EDE0;
  }

  /* Add to bag — desktop */
  .rukma-pdp__add-btn {
    background-color: #F5EDE0;
    color: #731C28;
    border: none;
    padding: 18px 56px;
    font-family: var(--font-body);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    cursor: pointer;
    align-self: flex-start;
    transition: background-color 0.2s;
  }

  .rukma-pdp__add-btn:hover {
    background-color: rgba(245, 237, 224, 0.85);
  }

  .rukma-pdp__add-btn:disabled {
    background-color: transparent;
    border: 1px solid rgba(245, 237, 224, 0.4);
    color: rgba(245, 237, 224, 0.6);
    opacity: 1;
    cursor: not-allowed;
  }

  /* ── Mobile sticky bar — cream, desktop hidden ── */
  .rukma-pdp__sticky-bar {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background-color: #F5EDE0;
  }

  .rukma-pdp__sticky-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 24px;
    gap: 1rem;
  }

  .rukma-pdp__sticky-title {
    font-family: var(--font-body);
    font-size: 0.75rem;
    letter-spacing: var(--letter-spacing-label);
    text-transform: uppercase;
    color: #2C2420;
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .rukma-pdp__sticky-right {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  .rukma-pdp__sticky-price {
    font-family: var(--font-body);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #8A7E76;
    white-space: nowrap;
  }

  .rukma-pdp__sticky-btn {
    background-color: #731C28;
    color: #F5EDE0;
    border: none;
    padding: 14px 28px;
    font-family: var(--font-body);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .rukma-pdp__inner {
      grid-template-columns: 1fr;
      padding-top: 4rem;
    }

    .rukma-pdp__media {
      position: relative;
      height: auto;
      padding: 2rem 1.5rem 1rem;
    }

    .rukma-pdp__image {
      max-height: 60vw;
    }

    .rukma-pdp__info {
      padding: 2rem 1.5rem 7rem;
    }

    .rukma-pdp__title {
      font-size: 2rem;
    }

    .rukma-pdp__add-btn {
      display: none;
    }

    .rukma-pdp__sticky-bar {
      display: flex;
      flex-direction: column;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var wraps = document.querySelectorAll('.rukma-pdp__image-wrap');
    var thumbs = document.querySelectorAll('.rukma-pdp__thumb');

    if (!thumbs.length) return;

    thumbs.forEach(function (thumb) {
      thumb.addEventListener('click', function () {
        var idx = thumb.dataset.index;
        wraps.forEach(function (w) { w.classList.remove('is-active'); });
        thumbs.forEach(function (t) { t.classList.remove('is-active'); });
        var target = document.querySelector('.rukma-pdp__image-wrap[data-index="' + idx + '"]');
        if (target) target.classList.add('is-active');
        thumb.classList.add('is-active');
      });
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:general.product",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
