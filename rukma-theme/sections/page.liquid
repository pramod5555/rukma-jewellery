<article class="rukma-page">
  <div class="rukma-page__inner">
    <header class="rukma-page__header">
      <span class="rukma-page__ornament" aria-hidden="true">✦</span>
      <h1 class="rukma-page__title">{{ page.title | escape }}</h1>
    </header>

    {%- if page.content != blank -%}
      <div class="rukma-page__content rte">
        {{ page.content }}
      </div>
    {%- endif -%}
  </div>
</article>

{% stylesheet %}
  .rukma-page {
    background: var(--color-bg, #F5EDE0);
    padding: 6rem 2rem 8rem;
  }

  .rukma-page__inner {
    max-width: 740px;
    margin: 0 auto;
  }

  .rukma-page__header {
    text-align: center;
    margin-bottom: 4rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(44, 36, 32, 0.1);
  }

  .rukma-page__ornament {
    font-size: 0.9rem;
    color: var(--color-gold, #C4A76D);
    letter-spacing: 0.4em;
    display: block;
    margin-bottom: 1.25rem;
  }

  .rukma-page__title {
    font-family: var(--font-heading);
    font-weight: 300;
    font-size: clamp(2rem, 5vw, 3.5rem);
    letter-spacing: -0.01em;
    color: var(--color-text, #2C2420);
    line-height: 1.15;
  }

  .rukma-page__content.rte {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.85;
    color: var(--color-text, #2C2420);
  }

  .rukma-page__content.rte h2,
  .rukma-page__content.rte h3 {
    font-family: var(--font-heading);
    font-weight: 300;
    color: var(--color-text, #2C2420);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .rukma-page__content.rte h2 {
    font-size: 1.8rem;
    letter-spacing: -0.01em;
  }

  .rukma-page__content.rte h3 {
    font-size: 1.3rem;
  }

  .rukma-page__content.rte p {
    margin-bottom: 1.5rem;
    color: var(--color-text-secondary, #8A7E76);
  }

  .rukma-page__content.rte a {
    color: var(--color-velvet, #731C28);
    border-bottom: 1px solid currentColor;
    padding-bottom: 0.05em;
    transition: opacity 0.2s;
  }

  .rukma-page__content.rte a:hover {
    opacity: 0.7;
  }

  .rukma-page__content.rte img {
    width: 100%;
    height: auto;
    display: block;
    margin: 2.5rem 0;
  }

  .rukma-page__content.rte ul,
  .rukma-page__content.rte ol {
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
    color: var(--color-text-secondary, #8A7E76);
  }

  .rukma-page__content.rte li {
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }

  .rukma-page__content.rte blockquote {
    border-left: 2px solid var(--color-gold, #C4A76D);
    padding: 0.5rem 0 0.5rem 1.5rem;
    margin: 2rem 0;
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 300;
    font-style: italic;
    color: var(--color-text, #2C2420);
    letter-spacing: 0.01em;
  }

  @media (max-width: 600px) {
    .rukma-page {
      padding: 4rem 1.25rem 5rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.page",
  "settings": []
}
{% endschema %}
