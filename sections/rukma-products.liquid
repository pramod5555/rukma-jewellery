<section class="rukma-products">
  {%- if section.settings.heading != blank -%}
    <div class="rukma-products__header">
      <h2 class="rukma-products__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.collection != blank -%}
        <a href="{{ section.settings.collection.url }}" class="rukma-products__view-all">
          {{- 'sections.rukma_products.view_all' | t -}}
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="rukma-products__grid">
    {%- assign product_limit = section.settings.product_count | default: 4 -%}
    {%- if section.settings.collection != blank -%}
      {%- for product in section.settings.collection.products limit: product_limit -%}
        <a
          href="{{ product.url }}"
          class="rukma-product-card{% if forloop.first %} rukma-product-card--featured{% endif %}"
        >
          <div class="rukma-product-card__image-wrap">
            {%- if product.featured_image -%}
              {{ product.featured_image
                | image_url: width: 1200
                | image_tag:
                  loading: 'lazy',
                  class: 'rukma-product-card__image',
                  alt: product.featured_image.alt | default: product.title
              }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'rukma-product-card__image' }}
            {%- endif -%}
          </div>
          <div class="rukma-product-card__info">
            <p class="rukma-product-card__title">{{ product.title }}</p>
            <p class="rukma-product-card__price">
              {%- if product.compare_at_price > product.price -%}
                <s class="rukma-product-card__was">{{ product.compare_at_price | money }}</s>
              {%- endif -%}
              {{- product.price | money -}}
            </p>
          </div>
        </a>
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..4) -%}
        <div class="rukma-product-card{% if forloop.first %} rukma-product-card--featured{% endif %}">
          <div class="rukma-product-card__image-wrap">
            {{ 'product-1' | placeholder_svg_tag: 'rukma-product-card__image' }}
          </div>
          <div class="rukma-product-card__info">
            <p class="rukma-product-card__title">{{ 'sections.rukma_products.sample_title' | t }}</p>
            <p class="rukma-product-card__price">—</p>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .rukma-products {
    padding: 7rem 0;
  }

  .rukma-products__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 4rem;
  }

  .rukma-products__heading {
    font-family: var(--font-heading);
    font-weight: 300;
    font-size: clamp(1.75rem, 3vw, 2.75rem);
    letter-spacing: -0.01em;
    color: var(--color-text);
  }

  .rukma-products__view-all {
    font-family: var(--font-body);
    font-size: 0.6rem;
    letter-spacing: var(--letter-spacing-label);
    text-transform: uppercase;
    color: var(--color-text-secondary);
    border-bottom: 1px solid currentColor;
    padding-bottom: 0.2rem;
    transition: color 0.2s;
  }

  .rukma-products__view-all:hover {
    color: var(--color-text);
  }

  .rukma-products__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    column-gap: 48px;
    row-gap: 80px;
  }

  /* Featured: first card spans full width */
  .rukma-product-card--featured {
    grid-column: 1 / -1;
  }

  .rukma-product-card {
    display: block;
    color: var(--color-text);
    background: transparent;
  }

  .rukma-product-card__image-wrap {
    aspect-ratio: 1 / 1;
    background-color: #F5EDE0;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    overflow: hidden;
    transition: background-color 0.4s ease;
  }

  .rukma-product-card:hover .rukma-product-card__image-wrap {
    background-color: #EDE6D8;
  }

  .rukma-product-card__image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .rukma-product-card__info {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .rukma-product-card__title {
    font-family: var(--font-heading);
    font-weight: 300;
    font-size: 1rem;
    letter-spacing: 0.05em;
    color: #2C2420;
  }

  .rukma-product-card__price {
    font-family: var(--font-body);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #8A7E76;
  }

  .rukma-product-card__was {
    margin-right: 0.5rem;
    opacity: 0.5;
  }

  @media (max-width: 640px) {
    .rukma-products {
      padding: 4rem 0;
    }

    .rukma-products__grid {
      grid-template-columns: repeat(2, 1fr);
      column-gap: 16px;
      row-gap: 40px;
    }

    .rukma-product-card--featured {
      grid-column: 1 / -1;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.rukma_products.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "New arrivals"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:labels.collection"
    },
    {
      "type": "range",
      "id": "product_count",
      "label": "t:sections.rukma_products.product_count",
      "min": 2,
      "max": 8,
      "step": 2,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "t:sections.rukma_products.name"
    }
  ]
}
{% endschema %}
