<section class="rukma-category-grid">
  <div class="rukma-category-grid__inner">

    {%- if section.settings.heading != blank -%}
      <h2 class="rukma-category-grid__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    <div class="rukma-category-grid__grid collection-list collections-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'category' -%}
          <a
            href="{{ block.settings.url | default: routes.all_products_collection_url }}"
            class="rukma-category-card collection-list__item collection-card"
            {{ block.shopify_attributes }}
          >
            <div class="rukma-category-card__img-wrap">
              {%- if block.settings.image -%}
                {{
                  block.settings.image
                  | image_url: width: 800
                  | image_tag:
                    loading: 'lazy',
                    class: 'rukma-category-card__img',
                    alt: block.settings.image.alt | default: block.settings.label
                }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'rukma-category-card__img rukma-category-card__img--placeholder' }}
              {%- endif -%}
            </div>
            <div class="rukma-category-card__label-wrap">
              <span class="rukma-category-card__label collection-card__title">{{ block.settings.label | escape }}</span>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{% stylesheet %}
  .rukma-category-grid {
    background: var(--color-bg, #F5EDE0);
    padding: 0;
  }

  .rukma-category-grid__inner {
    max-width: none;
    margin: 0;
    width: 100%;
  }

  .rukma-category-grid__heading {
    font-family: var(--font-heading);
    font-weight: 300;
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    letter-spacing: -0.01em;
    color: var(--color-text, #2C2420);
    margin-bottom: 3rem;
    text-align: center;
  }

  .collection-list,
  .collections-grid,
  .rukma-category-grid__grid,
  [class*="collection-list__grid"],
  [class*="collections-grid"] {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    padding: 0;
    margin: 0;
    width: 100%;
  }

  .collection-list__item,
  .collection-card,
  .rukma-category-card,
  [class*="collection-list__item"],
  [class*="collection-card"] {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    border: none;
    border-radius: 0;
    padding: 0;
    margin: 0;
    background: #EDE6D8;
    display: block;
    cursor: pointer;
  }

  .rukma-category-card__img-wrap {
    width: 100%;
    height: 100%;
  }

  .collection-list__item img,
  .collection-card img,
  .rukma-category-card__img,
  [class*="collection-card"] img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.6s ease;
  }

  .rukma-category-card__img--placeholder {
    opacity: 0.25;
  }

  .collection-list__item:hover img,
  .collection-card:hover img,
  .rukma-category-card:hover .rukma-category-card__img {
    transform: scale(1.04);
  }

  .rukma-category-card__label-wrap {
    display: contents;
  }

  .collection-list__item .card__heading,
  .collection-card__title,
  .rukma-category-card__label,
  [class*="collection"] h2,
  [class*="collection"] h3 {
    position: absolute;
    bottom: 1.5rem;
    left: 1.5rem;
    font-family: 'Nunito', sans-serif;
    font-size: clamp(0.7rem, 1vw, 0.85rem);
    font-weight: 500;
    letter-spacing: 0.28em;
    line-height: 1.2;
    text-transform: uppercase;
    color: #F5EDE0;
    background: rgba(44, 36, 32, 0.72);
    text-shadow: 0 1px 6px rgba(10, 4, 2, 0.45);
    margin: 0;
    padding: 0.65rem 0.85rem 0.6rem;
    max-width: calc(100% - 3rem);
    z-index: 3;
  }

  .collection-list__item::after,
  .collection-card::after,
  .rukma-category-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(10, 4, 2, 0.45) 0%,
      transparent 45%
    );
    pointer-events: none;
    z-index: 1;
  }

  @media (max-width: 768px) {
    .collection-list,
    .collections-grid,
    .rukma-category-grid__grid,
    [class*="collection-list__grid"] {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .rukma-category-grid__grid {
      grid-template-columns: 1fr;
    }

    .rukma-category-grid {
      padding: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "RUKMA category grid",
  "max_blocks": 6,
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Text",
          "default": "Heritage"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    }
  ],
  "presets": [
    {
      "name": "RUKMA category grid",
      "blocks": [
        { "type": "category", "settings": { "label": "Heritage" } },
        { "type": "category", "settings": { "label": "Men" } },
        { "type": "category", "settings": { "label": "Women" } }
      ]
    }
  ]
}
{% endschema %}
