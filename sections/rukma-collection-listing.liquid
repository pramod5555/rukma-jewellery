<section
  class="rukma-collection-listing"
  style="
    --rukma-collection-bg: {{ section.settings.background_color }};
    --rukma-collection-surface: {{ section.settings.surface_color }};
    --rukma-collection-accent: {{ section.settings.accent_color }};
  "
>
  <header class="rukma-collection-listing-header">
    <div>
      {%- if section.settings.breadcrumb != blank -%}
        <p class="rukma-collection-listing-breadcrumb">{{ section.settings.breadcrumb | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1 class="rukma-collection-listing-heading">{{ section.settings.heading }}</h1>
      {%- endif -%}
    </div>

    {%- if section.settings.filter_label != blank -%}
      <button class="rukma-collection-listing-filter" type="button">
        <span>{{ section.settings.filter_label | escape }}</span>
        <span aria-hidden="true">+</span>
      </button>
    {%- endif -%}
  </header>

  <div class="rukma-collection-listing-grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'product' -%}
        <a
          href="{{ block.settings.link | default: routes.all_products_collection_url }}"
          class="rukma-collection-listing-card{% if block.settings.featured %} rukma-collection-listing-card-featured{% endif %}"
          {{ block.shopify_attributes }}
        >
          <div class="rukma-collection-listing-media{% if block.settings.featured %} rukma-collection-listing-media-featured{% endif %}">
            {%- if block.settings.image -%}
              <img
                src="{{ block.settings.image | img_url: '1400x' }}"
                alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                class="rukma-collection-listing-image"
                width="1400"
                height="1750"
                loading="lazy"
              >
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'rukma-collection-listing-image rukma-collection-listing-placeholder' }}
            {%- endif -%}
            {%- if block.settings.badge != blank -%}
              <span class="rukma-collection-listing-badge">{{ block.settings.badge | escape }}</span>
            {%- endif -%}
          </div>
          <div class="rukma-collection-listing-info">
            <div>
              <h2 class="rukma-collection-listing-title">{{ block.settings.title | escape }}</h2>
              <p class="rukma-collection-listing-subtitle">{{ block.settings.subtitle | escape }}</p>
            </div>
            <p class="rukma-collection-listing-price">{{ block.settings.price | escape }}</p>
          </div>
        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div class="rukma-collection-listing-pagination">
    {%- if section.settings.count_label != blank -%}
      <p class="rukma-collection-listing-count">{{ section.settings.count_label | escape }}</p>
    {%- endif -%}
    {%- if section.settings.load_more_label != blank -%}
      <a href="{{ section.settings.load_more_link | default: routes.all_products_collection_url }}" class="rukma-collection-listing-load">
        {{ section.settings.load_more_label | escape }}
      </a>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .rukma-collection-listing,
  .rukma-collection-listing * {
    border-radius: 0;
  }

  .rukma-collection-listing {
    background: var(--rukma-collection-bg, var(--color-bg));
    color: var(--color-text);
    font-family: var(--font-body);
    padding: 0;
  }

  .rukma-collection-listing-header,
  .rukma-collection-listing-grid,
  .rukma-collection-listing-pagination {
    max-width: none;
  }

  .collection-hero,
  .collection__title-wrapper,
  .rukma-collection-listing-header,
  .collection-header,
  [class*="collection-hero"],
  [class*="collection-header"] {
    display: flex;
    flex-direction: row;
    align-items: flex-end;
    justify-content: space-between;
    padding: 2.5rem 2.5rem 1.5rem;
    width: 100%;
    border-bottom: 1px solid rgba(44, 36, 32, 0.1);
    margin: 0;
  }

  .collection__title-wrapper {
    order: -1;
    align-self: flex-start;
    justify-self: flex-start;
    margin-right: auto;
  }

  .rukma-collection-listing-breadcrumb,
  .rukma-collection-listing-filter,
  .rukma-collection-listing-subtitle,
  .rukma-collection-listing-badge,
  .rukma-collection-listing-count,
  .rukma-collection-listing-load {
    font-family: var(--font-body);
    letter-spacing: var(--letter-spacing-label);
    text-transform: uppercase;
  }

  .rukma-collection-listing-breadcrumb {
    margin: 0;
    font-size: 0.62rem;
    color: #8A7E76;
  }

  .collection__title,
  .collection-hero__title,
  h1.collection-title,
  [class*="collection__title"],
  .rukma-collection-listing-heading {
    text-align: left;
    margin: 0;
    float: none;
    font-family: 'Nunito', sans-serif;
    font-size: clamp(0.7rem, 1vw, 0.85rem);
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #8A7E76;
  }

  .rukma-collection-listing-heading p {
    margin: 0;
  }

  .rukma-collection-listing-heading br {
    display: none;
  }

  .facets-container,
  .collection-filters,
  .rukma-collection-listing-filter,
  [class*="facets"] {
    display: inline-flex;
    align-items: flex-end;
    justify-content: flex-end;
    gap: 0.75rem;
    padding: 0;
    border: none;
    background: transparent;
    margin-bottom: 0;
    cursor: pointer;
  }

  [class*="facets__summary"],
  [class*="sort-by"],
  .rukma-collection-listing-filter {
    font-family: 'Nunito', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #8A7E76;
  }

  .collection-grid,
  .product-grid,
  ul.grid,
  [class*="product-grid"],
  .rukma-collection-listing-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
    padding: 0 1rem;
    margin: 0;
    width: 100%;
    list-style: none;
  }

  .card-wrapper,
  .product-card,
  .grid__item,
  [class*="card-wrapper"],
  .rukma-collection-listing-card {
    border: none;
    border-radius: 0;
    box-shadow: none;
    background: transparent;
    padding: 0.5rem;
    margin: 0;
    position: relative;
    color: var(--color-text);
  }

  .rukma-collection-listing-card-featured {
    grid-column: auto;
  }

  .card,
  .product-card__inner,
  [class*="card--product"] {
    border: none;
    border-radius: 0;
    box-shadow: none;
    background: transparent;
    padding: 0;
  }

  .card__media,
  .product-card__image-wrapper,
  [class*="card__media"],
  .rukma-collection-listing-media {
    position: relative;
    aspect-ratio: 2 / 3;
    overflow: hidden;
    margin-bottom: 0;
    background: transparent;
    border-radius: 0;
  }

  .rukma-collection-listing-media-featured {
    aspect-ratio: 2 / 3;
  }

  .card__media img,
  .product-card__image,
  [class*="card__media"] img,
  .rukma-collection-listing-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: bottom center;
    display: block;
    transition: transform 0.5s ease;
    background: transparent;
  }

  .card-wrapper:hover .card__media img,
  .grid__item:hover img,
  .rukma-collection-listing-card:hover .rukma-collection-listing-image {
    transform: scale(1.04);
  }

  .rukma-collection-listing-badge {
    position: absolute;
    top: 1.5rem;
    left: 1.5rem;
    padding: 0.35rem 0.7rem;
    background: var(--rukma-collection-accent, var(--color-velvet));
    color: var(--color-bg);
    font-size: 0.58rem;
  }

  .card__badge,
  .price__badge,
  [class*="badge"] {
    display: none !important;
  }

  .card__badge .badge,
  [class*="card__badge"],
  .rukma-collection-listing-badge {
    display: inline-block !important;
    visibility: visible !important;
    position: absolute;
    top: 0.5rem;
    left: 0.5rem;
    z-index: 2;
    font-family: 'Nunito', sans-serif;
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    background: #731C28;
    color: #F5EDE0;
    border-radius: 0;
    padding: 0.2rem 0.5rem;
  }

  .card__content,
  .card__information,
  .product-card__info,
  [class*="card__information"],
  .rukma-collection-listing-info {
    display: flex !important;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    gap: 0;
    visibility: visible !important;
    padding: 0.9rem 0.75rem 1.9rem;
    text-align: center;
    width: 100%;
    min-height: 6.25rem;
    overflow: hidden;
    background: transparent;
    border: none;
  }

  .rukma-collection-listing-info > div {
    display: block;
    width: 100%;
    min-height: 0;
    margin: 0;
  }

  .card__heading,
  .card__heading a,
  .product-card__title,
  [class*="card__heading"],
  [class*="card__heading"] a,
  .rukma-collection-listing-title {
    display: block !important;
    visibility: visible !important;
    width: 100%;
    margin: 0;
    font-family: 'Nunito', sans-serif;
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #2C2420 !important;
    text-decoration: none;
    text-align: center;
    white-space: normal;
    word-break: break-word;
    overflow-wrap: anywhere;
    overflow: hidden;
    line-height: 1.45;
    max-width: 24ch;
    min-height: 2.8rem;
  }

  .card__heading a:hover {
    color: #731C28 !important;
  }

  .rukma-collection-listing-subtitle {
    display: none;
  }

  .price,
  .price__container,
  .price__regular,
  .price__sale,
  .product-card__price,
  [class*="price-item"],
  [class*="price"],
  .rukma-collection-listing-price {
    display: block !important;
    visibility: visible !important;
    width: 100%;
    margin: 0.45rem 0 0;
    position: static !important;
    clear: both;
    flex: 0 0 auto;
    font-family: 'Inter', sans-serif;
    font-size: 0.64rem;
    font-weight: 300;
    letter-spacing: 0.04em;
    color: #8A7E76 !important;
    white-space: nowrap;
    text-align: center;
    line-height: 1.4;
  }

  .price--on-sale .price__regular {
    text-decoration: line-through;
    color: #C4A76D !important;
  }

  .card-wrapper,
  .grid__item,
  [class*="card-wrapper"],
  .rukma-collection-listing-card {
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }

  .rukma-collection-listing-pagination {
    padding-top: 6rem;
    text-align: center;
  }

  .rukma-collection-listing-count {
    margin: 0 0 1.5rem;
    color: var(--color-text-secondary);
    font-size: 0.6rem;
  }

  .rukma-collection-listing-load {
    display: inline-block;
    padding: 1rem 3rem;
    background: var(--rukma-collection-accent, var(--color-velvet));
    color: var(--color-bg);
    font-size: 0.7rem;
  }

  .rukma-collection-listing-placeholder {
    opacity: 0.28;
  }

  @media (max-width: 900px) {
    .rukma-collection-listing-header {
      align-items: center;
    }
  }

  @media (max-width: 1200px) {
    .collection-grid,
    .product-grid,
    ul.grid,
    .rukma-collection-listing-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 900px) {
    .collection-grid,
    .product-grid,
    ul.grid,
    .rukma-collection-listing-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 600px) {
    .collection-grid,
    .product-grid,
    ul.grid,
    .rukma-collection-listing-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "RUKMA collection listing",
  "settings": [
    { "type": "text", "id": "breadcrumb", "label": "Breadcrumb", "default": "Collections / New Arrivals" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Handcrafted Curations</p>" },
    { "type": "text", "id": "filter_label", "label": "Filter label", "default": "Filter & Sort" },
    { "type": "text", "id": "count_label", "label": "Count label", "default": "Showing 7 of 42 Items" },
    { "type": "text", "id": "load_more_label", "label": "Load more label", "default": "Load More Pieces" },
    { "type": "url", "id": "load_more_link", "label": "Load more link" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#F5EDE0" },
    { "type": "color", "id": "surface_color", "label": "Surface color", "default": "#EDE6D8" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#731C28" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "checkbox", "id": "featured", "label": "Large featured card", "default": false },
        { "type": "text", "id": "badge", "label": "Badge" },
        { "type": "text", "id": "title", "label": "Title", "default": "Mandala Heritage Choker" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Gold & Burmese Rubies" },
        { "type": "text", "id": "price", "label": "Price", "default": "$4,250" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "RUKMA collection listing",
      "blocks": [
        { "type": "product", "settings": { "featured": true, "badge": "New", "title": "Mandala Heritage Choker", "subtitle": "Gold & Burmese Rubies", "price": "$4,250" } },
        { "type": "product", "settings": { "title": "Lotus Bloom Studs", "subtitle": "22k Gold & Basra Pearl", "price": "$890" } },
        { "type": "product", "settings": { "title": "Vayu Kada Bracelet", "subtitle": "Gold & Zambian Emerald", "price": "$1,550" } },
        { "type": "product", "settings": { "title": "Prithvi Uncut Ring", "subtitle": "Polki Diamond", "price": "$2,100" } },
        { "type": "product", "settings": { "title": "Akasha Pendant", "subtitle": "Satin Finish Gold", "price": "$1,200" } }
      ]
    }
  ]
}
{% endschema %}
